#!/usr/bin/env bash
# Copilot hook: error-occurred
# Generated by amplihack

LOG_DIR="$HOME/.amplihack/.claude/runtime/logs"

mkdir -p "$LOG_DIR"
INPUT=$(cat)
ERROR_MSG=$(printf '%s' "$INPUT" | tr '
' ' ' | sed -n 's/.*"message"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
if [[ -z "$ERROR_MSG" ]]; then
ERROR_MSG=$(printf '%s' "$INPUT" | tr '
' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-500)
fi
if [[ -z "$ERROR_MSG" ]]; then
ERROR_MSG="unknown"
fi
echo "$(date -Iseconds): ERROR - $ERROR_MSG" >> "${LOG_DIR}/errors.log"
echo "{}"
