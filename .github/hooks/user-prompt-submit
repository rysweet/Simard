#!/usr/bin/env bash
# Copilot hook wrapper - generated by amplihack
# Runs multiple hook handlers for this event
HOOKS_BIN="${AMPLIHACK_HOOKS_BIN:-}"
if [[ -z "$HOOKS_BIN" ]]; then
if [[ -x "$HOME/.local/bin/amplihack-hooks" ]]; then
HOOKS_BIN="$HOME/.local/bin/amplihack-hooks"
elif command -v amplihack-hooks >/dev/null 2>&1; then
HOOKS_BIN="$(command -v amplihack-hooks)"
fi
fi
INPUT=$(cat)

if [[ -n "$HOOKS_BIN" ]] && [[ -x "$HOOKS_BIN" ]]; then
printf '%s' "$INPUT" | "$HOOKS_BIN" workflow-classification-reminder "$@" >/dev/null 2>/dev/null || true
fi

if [[ -n "$HOOKS_BIN" ]] && [[ -x "$HOOKS_BIN" ]]; then
printf '%s' "$INPUT" | "$HOOKS_BIN" user-prompt-submit "$@" >/dev/null 2>/dev/null || true
fi
